@model IEnumerable<MyPocket.Core.Models.Category>

@{
    ViewData["Title"] = Localizer["CategoriesManagement"];
    Func<MyPocket.Core.Models.Category, bool> isAdminCategory = c => c.User != null && c.User.Email == "admin@example.com";
    var incomeCategories = Model.Where(c => c.CategoryType == "收入").ToList();
    var expenseCategories = Model.Where(c => c.CategoryType == "支出").ToList();
}

<h1>@Localizer["CategoriesManagement"]</h1>

<div class="row mb-3">
    <div class="col-md-4 mb-2">
        <input type="text" id="tableFilter" class="form-control" placeholder="@Localizer["Search"]...">
    </div>
    <div class="col-md-3 mb-2">
        <select id="typeFilter" class="form-select">
            <option value="">@Localizer["AllTypes"]</option>
            <option value="收入">@Localizer["Income"]</option>
            <option value="支出">@Localizer["Expense"]</option>
        </select>
    </div>
    <div class="col-md-3 mb-2 d-flex align-items-center">
        <input type="checkbox" id="showUserCategory" class="form-check-input me-2">
        <label for="showUserCategory" class="form-check-label">@Localizer["ShowUserCategories"]</label>
    </div>
    <div class="col-md-2 mb-2 text-end">
        <a asp-action="Create" class="btn btn-success">@Localizer["AddCategory"]</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 category-block" data-block="收入">
        <div class="card mb-4">
            <div class="card-header bg-success text-white">@Localizer["IncomeCategories"]</div>
            <div class="card-body p-0">
                <table class="table table-striped align-middle mb-0 category-table" data-type="收入">
                    <thead>
                        <tr>
                            <th>@Localizer["CategoryName"]</th>
                            <th>@Localizer["Source"]</th>
                            <th>@Localizer["Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in incomeCategories)
                        {
                            var isAdmin = isAdminCategory(item);
                            <tr data-type="收入" data-admin="@(isAdmin ? "1" : "0")">
                                <td>@Localizer[item.CategoryName]</td>
                                <td>
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-primary">@Localizer["Admin"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">@Localizer["User"]</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary">@Localizer["Edit"]</a>
                                    <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-secondary">@Localizer["Details"]</a>
                                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6 category-block" data-block="支出">
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">@Localizer["ExpenseCategories"]</div>
            <div class="card-body p-0">
                <table class="table table-striped align-middle mb-0 category-table" data-type="支出">
                    <thead>
                        <tr>
                            <th>@Localizer["CategoryName"]</th>
                            <th>@Localizer["Source"]</th>
                            <th>@Localizer["Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in expenseCategories)
                        {
                            var isAdmin = isAdminCategory(item);
                            <tr data-type="支出" data-admin="@(isAdmin ? "1" : "0")">
                                <td>@Localizer[item.CategoryName]</td>
                                <td>
                                    @if (isAdmin)
                                    {
                                        <span class="badge bg-primary">@Localizer["Admin"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">@Localizer["User"]</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-primary">@Localizer["Edit"]</a>
                                    <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-secondary">@Localizer["Details"]</a>
                                    <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function filterTable() {
        var text = $('#tableFilter').val().toLowerCase();
        var type = $('#typeFilter').val();
        var showUser = $('#showUserCategory').is(':checked');

        // Block visibility based on the type filter.
        if (type === "") {
            $('.category-block').show();
        } else {
            $('.category-block').each(function () {
                $(this).toggle($(this).data('block') === type);
            });
        }

        // Row visibility based on text and admin/user filter.
        $('.category-table tbody tr').each(function () {
            var row = $(this);
            var isAdmin = row.data('admin') == 1;
            var matchText = row.text().toLowerCase().indexOf(text) > -1;
            var matchUser = showUser || isAdmin;
            row.toggle(matchText && matchUser);
        });
    }
    $(document).ready(function () {
        $('#tableFilter, #typeFilter, #showUserCategory').on('input change', filterTable);
        filterTable();
    });
</script>
