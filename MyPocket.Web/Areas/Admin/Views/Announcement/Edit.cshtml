@model MyPocket.Core.Models.Announcement
@{
    ViewData["Title"] = Localizer["EditAnnouncement"];
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<h2>@Localizer["EditAnnouncement"]</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="AnnouncementId" />
    <div class="mb-3">
        <label asp-for="Title" class="form-label">@Localizer["Title"]</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Content" class="form-label">@Localizer["Content"]</label>
        <textarea asp-for="Content" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-warning">@Localizer["Save"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Back"]</a>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
