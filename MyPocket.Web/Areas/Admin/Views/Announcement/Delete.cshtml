@model MyPocket.Core.Models.Announcement
@{
    ViewData["Title"] = Localizer["DeleteAnnouncement"];
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<h2>@Localizer["DeleteAnnouncement"]</h2>
<div class="alert alert-danger">
    <strong>@Localizer["ConfirmDeleteAnnouncement"]</strong>
</div>
<div class="card mb-3">
    <div class="card-body">
        <h4 class="card-title">@Model.Title</h4>
        <div class="text-muted mb-2">@Localizer["PublishDate"]: @Model.PublishDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        <div>@Model.Content</div>
    </div>
</div>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AnnouncementId" />
    <button type="submit" class="btn btn-danger">@Localizer["ConfirmDelete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>
