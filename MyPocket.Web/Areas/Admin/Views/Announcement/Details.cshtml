@model MyPocket.Core.Models.Announcement
@{
    ViewData["Title"] = Localizer["AnnouncementDetails"];
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<h2>@Localizer["AnnouncementDetails"]</h2>
<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.Title</h4>
        <div class="text-muted mb-2">@Localizer["PublishDate"]: @Model.PublishDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
        <div>@Model.Content</div>
    </div>
</div>
<a asp-action="Index" class="btn btn-secondary mt-3">@Localizer["Back"]</a>
