@model IEnumerable<MyPocket.Core.Models.SubscriptionPlan>

@{
    ViewData["Title"] = Localizer["SubscriptionPlansManagement"];
}

<h1>@Localizer["SubscriptionPlansManagement"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">@Localizer["AddSubscriptionPlan"]</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PlanName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DurationDays)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>@Localizer["Action"]</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Localizer[item.PlanName]
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DurationDays)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.PlanId" class="btn btn-info btn-sm">@Localizer["Edit"]</a> |
                <a asp-action="Delete" asp-route-id="@item.PlanId" class="btn btn-danger btn-sm">@Localizer["Delete"]</a>
            </td>
        </tr>
}
    </tbody>
</table>
