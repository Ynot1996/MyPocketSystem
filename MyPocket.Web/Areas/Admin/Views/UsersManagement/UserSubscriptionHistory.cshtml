@model MyPocket.Core.Models.User
@{
    ViewData["Title"] = $"{Localizer["UserSubscriptionHistory"]} - {Model.Email}";
}

<div class="container-fluid">
    <h1 class="mt-4">@ViewData["Title"]</h1>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    @Localizer["UserInfo"]
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">@Localizer["EmailAddress"]</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">@Localizer["Nickname"]</dt>
                        <dd class="col-sm-8">@Model.Nickname</dd>

                        <dt class="col-sm-4">@Localizer["Role"]</dt>
                        <dd class="col-sm-8">@Model.Role</dd>

                        <dt class="col-sm-4">@Localizer["RegistrationDate"]</dt>
                        <dd class="col-sm-8">@Model.CreationDate.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    @Localizer["UpdateSubscription"]
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-action="UpdateSubscription" method="post">
                        <input type="hidden" name="userId" value="@Model.UserId" />
                        <div class="form-group">
                            <label>@Localizer["SelectNewPlan"]</label>
                            <select name="planId" class="form-control">
                                @foreach (var plan in (IEnumerable<MyPocket.Core.Models.SubscriptionPlan>)ViewBag.SubscriptionPlans)
                                {
                                    <option value="@plan.PlanId">@Localizer[plan.PlanName] - @plan.Price.ToString("C0")</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary mt-3">@Localizer["UpdateSubscription"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            @Localizer["SubscriptionHistory"]
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>@Localizer["SubscriptionPlan"]</th>
                            <th>@Localizer["StartDate"]</th>
                            <th>@Localizer["EndDate"]</th>
                            <th>@Localizer["Status"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var subscription in Model.UserSubscriptions.OrderByDescending(s => s.StartDate))
                        {
                            <tr>
                                <td>@Localizer[subscription.Plan.PlanName]</td>
                                <td>@subscription.StartDate.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                <td>@subscription.EndDate.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                <td>@subscription.Status</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">@Localizer["BackToList"]</a>
    </div>
</div>
