@model IEnumerable<MyPocket.Core.Models.User>
@{
    ViewData["Title"] = Localizer["UsersSubscription"];
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var confirmBulkUpdate = Localizer["ConfirmBulkSubscriptionUpdate"];
    var errorPrefix = Localizer["ErrorPrefix"];
    var bulkUpdateErrorPrefix = Localizer["BulkUpdateError"];
}

<h1>@Localizer["UsersSubscription"]</h1>

<div class="mb-2">
    <input type="text" id="tableFilter" class="form-control" placeholder="@Localizer["Search"]...">
</div>

<div class="alert alert-info">
    @Localizer["UsersSubscriptionHint"]
    <ul>
        <li>@Localizer["UsersSubscriptionHint1"]</li>
        <li>@Localizer["UsersSubscriptionHint2"]</li>
    </ul>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<form id="subscriptionForm">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>
                        <input type="checkbox" id="selectAll" />
                    </th>
                    <th>@Localizer["EmailAddress"]</th>
                    <th>@Localizer["Nickname"]</th>
                    <th>@Localizer["Role"]</th>
                    <th>@Localizer["CurrentSubscription"]</th>
                    <th>@Localizer["SubscriptionEndDate"]</th>
                    <th>@Localizer["Action"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var currentSub = user.UserSubscriptions?.OrderByDescending(us => us.StartDate).FirstOrDefault();
                    <tr>
                        <td>
                            <input type="checkbox" name="selectedUsers" value="@user.UserId" class="user-checkbox" />
                        </td>
                        <td>@user.Email</td>
                        <td>@user.Nickname</td>
                        <td>@user.Role</td>
                        <td>@(currentSub?.Plan?.PlanName != null ? Localizer[currentSub.Plan.PlanName] : Localizer["NoSubscription"])</td>
                        <td>@(currentSub?.EndDate.ToString("yyyy/MM/dd") ?? "---")</td>
                        <td>
                            <a asp-action="UserSubscriptionHistory" asp-route-userId="@user.UserId"
                               class="btn btn-info btn-sm">@Localizer["Details"]</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">@Localizer["BulkUpdateSubscription"]</h5>
            <div class="row">
                <div class="col-md-6">
                    <select id="planSelection" class="form-control">
                        <option value="">@Localizer["SelectAPlan"]...</option>
                        @foreach (var plan in (IEnumerable<MyPocket.Core.Models.SubscriptionPlan>)ViewBag.SubscriptionPlans)
                        {
                            <option value="@plan.PlanId">@Localizer[plan.PlanName]</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <button type="button" id="updateSelected" class="btn btn-primary" disabled>
                        @Localizer["UpdateSelectedUsers"]
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Select-all toggle
            $("#selectAll").change(function () {
                $(".user-checkbox").prop('checked', $(this).prop('checked'));
                updateButtonState();
            });

            // Sync individual rows back to the header checkbox
            $(".user-checkbox").change(function () {
                updateButtonState();
                var allChecked = $(".user-checkbox:not(:checked)").length === 0;
                $("#selectAll").prop('checked', allChecked);
            });

            $("#planSelection").change(function () {
                updateButtonState();
            });

            function updateButtonState() {
                var hasSelection = $(".user-checkbox:checked").length > 0;
                var hasPlan = $("#planSelection").val() !== "";
                $("#updateSelected").prop('disabled', !hasSelection || !hasPlan);
            }

            $("#updateSelected").click(function (e) {
                e.preventDefault();

                if (!confirm("@confirmBulkUpdate")) {
                    return;
                }

                var selectedUsers = [];
                $(".user-checkbox:checked").each(function () {
                    selectedUsers.push($(this).val());
                });

                var planId = $("#planSelection").val();

                // Disable while the request is in flight to prevent duplicate submissions.
                $("#updateSelected").prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("UpdateSelectedSubscriptions")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        userIds: selectedUsers,
                        planId: planId
                    }),
                    success: function (result) {
                        if (result.success) {
                            alert(result.message);
                            location.reload();
                        } else {
                            alert('@errorPrefix' + result.message);
                            updateButtonState();
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('@bulkUpdateErrorPrefix' + error);
                        updateButtonState();
                    }
                });
            });
        });
    </script>
}
