@model MyPocket.Shared.ViewModels.Users.UserProfileViewModel
@{
    ViewData["Title"] = Localizer["ProfileInfo"];
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
<h2>@Localizer["ProfileInfo"]</h2>
<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Localizer["EmailAddress"]</dt>
            <dd class="col-sm-9">@Model.Email</dd>
            <dt class="col-sm-3">@Localizer["Nickname"]</dt>
            <dd class="col-sm-9">@Model.Nickname</dd>
            <dt class="col-sm-3">@Localizer["RegistrationDate"]</dt>
            <dd class="col-sm-9">@Model.CreationDate.ToString("yyyy-MM-dd HH:mm")</dd>
            <dt class="col-sm-3">@Localizer["LastLogin"]</dt>
            <dd class="col-sm-9">@Model.LastLoginDate.ToString("yyyy-MM-dd HH:mm")</dd>
        </dl>
        <a asp-action="Edit" class="btn btn-primary">@Localizer["EditNickname"]</a>
    </div>
</div>
