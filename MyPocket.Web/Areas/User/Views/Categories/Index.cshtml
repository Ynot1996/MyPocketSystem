@model MyPocket.Shared.ViewModels.Categories.UserCategoryViewModel
@{
    ViewData["Title"] = Localizer["MyCategories"];
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-info">
                @Localizer["CategoriesHint"]
            </div>
        </div>
    </div>
    <ul class="nav nav-pills mb-3" id="categoryTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="income-tab" data-bs-toggle="pill" data-bs-target="#income" type="button" role="tab" aria-controls="income" aria-selected="true">@Localizer["IncomeCategories"]</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="expense-tab" data-bs-toggle="pill" data-bs-target="#expense" type="button" role="tab" aria-controls="expense" aria-selected="false">@Localizer["ExpenseCategories"]</button>
        </li>
    </ul>
    <div class="tab-content" id="categoryTabContent">
        <div class="tab-pane fade show active" id="income" role="tabpanel" aria-labelledby="income-tab">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-light">@Localizer["DefaultIncomeCategories"]</div>
                        <ul class="list-group list-group-flush">
                            @if (Model.DefaultIncomeCategories.Any())
                            {
                                foreach (var c in Model.DefaultIncomeCategories)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><i class="bi @MyPocket.Web.Services.CategoryIcons.For(c.CategoryName) me-2 text-muted"></i>@Localizer[c.CategoryName]</span>
                                        <span class="badge bg-secondary">@Localizer["Default"]</span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-muted">@Localizer["NoDefaultIncomeCategories"]</li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-light">@Localizer["CustomIncomeCategories"]</div>
                        <ul class="list-group list-group-flush">
                            @if (Model.UserIncomeCategories.Any())
                            {
                                foreach (var c in Model.UserIncomeCategories)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><i class="bi @MyPocket.Web.Services.CategoryIcons.For(c.CategoryName) me-2 text-muted"></i>@c.CategoryName</span>
                                        <form asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                        </form>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-muted">@Localizer["NoCustomIncomeCategories"]</li>
                            }
                        </ul>
                        <div class="card-footer bg-white">
                            <form asp-action="Create" method="post" class="input-group">
                                <input type="hidden" name="newCategoryType" value="收入" />
                                <input type="text" name="newCategoryName" class="form-control" placeholder="@Localizer["AddIncomeCategoryPlaceholder"]" required />
                                <button class="btn btn-primary" type="submit">@Localizer["Add"]</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="tab-pane fade" id="expense" role="tabpanel" aria-labelledby="expense-tab">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-light">@Localizer["DefaultExpenseCategories"]</div>
                        <ul class="list-group list-group-flush">
                            @if (Model.DefaultExpenseCategories.Any())
                            {
                                foreach (var c in Model.DefaultExpenseCategories)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><i class="bi @MyPocket.Web.Services.CategoryIcons.For(c.CategoryName) me-2 text-muted"></i>@Localizer[c.CategoryName]</span>
                                        <span class="badge bg-secondary">@Localizer["Default"]</span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-muted">@Localizer["NoDefaultExpenseCategories"]</li>
                            }
                        </ul>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-header bg-light">@Localizer["CustomExpenseCategories"]</div>
                        <ul class="list-group list-group-flush">
                            @if (Model.UserExpenseCategories.Any())
                            {
                                foreach (var c in Model.UserExpenseCategories)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span><i class="bi @MyPocket.Web.Services.CategoryIcons.For(c.CategoryName) me-2 text-muted"></i>@c.CategoryName</span>
                                        <form asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">@Localizer["Delete"]</button>
                                        </form>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-muted">@Localizer["NoCustomExpenseCategories"]</li>
                            }
                        </ul>
                        <div class="card-footer bg-white">
                            <form asp-action="Create" method="post" class="input-group">
                                <input type="hidden" name="newCategoryType" value="支出" />
                                <input type="text" name="newCategoryName" class="form-control" placeholder="@Localizer["AddExpenseCategoryPlaceholder"]" required />
                                <button class="btn btn-primary" type="submit">@Localizer["Add"]</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
