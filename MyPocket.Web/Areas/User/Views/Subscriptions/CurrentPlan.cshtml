@model MyPocket.Core.Models.UserSubscription
@{
    ViewData["Title"] = Localizer["CurrentPlan"];
    var confirmCancel = Localizer["ConfirmCancelSubscriptionLong"];
}

<div class="container py-5">
    <h2 class="mb-4">@Localizer["CurrentPlan"]</h2>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title text-primary">@Localizer[Model.Plan.PlanName]</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>@Localizer["SubscriptionStartDate"]:</strong></p>
                            <p>@Model.StartDate.ToLocalTime().ToString("yyyy/MM/dd")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>@Localizer["SubscriptionEndDate"]:</strong></p>
                            <p>@Model.EndDate.ToLocalTime().ToString("yyyy/MM/dd")</p>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h6>@Localizer["PlanContent"]:</h6>
                        @foreach (var line in (Model.Plan.Description ?? "").Split('\n'))
                        {
                            <p class="mb-1">@line</p>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Plans" class="btn btn-outline-primary">
                            @Localizer["ViewAllPlans"]
                        </a>
                        <form asp-action="Cancel" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('@confirmCancel');">
                                @Localizer["CancelSubscription"]
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            @if (Model.Payments.Any())
            {
                <div class="card mt-4">
                    <div class="card-body">
                        <h5 class="card-title">@Localizer["PaymentHistory"]</h5>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>@Localizer["PaymentDate"]</th>
                                        <th>@Localizer["Amount"]</th>
                                        <th>@Localizer["PaymentMethod"]</th>
                                        <th>@Localizer["Status"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in Model.Payments.OrderByDescending(p => p.PaymentDate))
                                    {
                                        <tr>
                                            <td>@payment.PaymentDate.ToLocalTime().ToString("yyyy/MM/dd HH:mm")</td>
                                            <td>NT$ @payment.PaymentAmount.ToString("N0")</td>
                                            <td>@payment.PaymentWay</td>
                                            <td>
                                                <span class="badge @(payment.Status == "Completed" ? "bg-success" : "bg-warning")">
                                                    @payment.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@Localizer["SubscriptionReminder"]</h5>
                    <p>@string.Format(Localizer["SubscriptionExpiresInDays"], (Model.EndDate - DateTime.UtcNow).Days)</p>

                    @if ((Model.EndDate - DateTime.UtcNow).Days < 7)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            @Localizer["SubscriptionExpiringWarning"]
                        </div>
                    }

                    <a asp-action="Plans" class="btn btn-primary w-100">@Localizer["RenewService"]</a>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    <h5 class="card-title">@Localizer["NeedHelp"]</h5>
                    <p class="card-text">@Localizer["NeedHelpDescription"]</p>
                    <a href="mailto:support@mypocket.com" class="btn btn-outline-primary w-100">
                        <i class="bi bi-envelope"></i> @Localizer["ContactSupport"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
