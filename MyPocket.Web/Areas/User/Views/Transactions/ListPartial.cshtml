@model IEnumerable<MyPocket.Core.Models.Transaction>
@{
    var incomeList = Model.Where(x => x.TransactionType.Trim() == "收入").ToList();
    var expenseList = Model.Where(x => x.TransactionType.Trim() == "支出").ToList();
    var confirmDelete = Localizer["ConfirmDeleteTransaction"];
}
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3 fw-bold text-success">@Localizer["IncomeRecords"]</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["Amount"]</th>
                        <th>@Localizer["Description"]</th>
                        <th>@Localizer["Action"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!incomeList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">@Localizer["NoIncomeRecords"]</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in incomeList)
                        {
                            <tr>
                                <td>@item.TransactionDate.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>@Localizer[item.Category.CategoryName]</td>
                                <td class="text-success fw-bold">+@item.Amount.ToString("N0")</td>
                                <td>@item.Description</td>
                                <td>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.TransactionId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('@confirmDelete');">
                                            @Localizer["Delete"]
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3 fw-bold text-danger">@Localizer["ExpenseRecords"]</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>@Localizer["Date"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["Amount"]</th>
                        <th>@Localizer["Description"]</th>
                        <th>@Localizer["Action"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!expenseList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">@Localizer["NoExpenseRecords"]</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in expenseList)
                        {
                            <tr>
                                <td>@item.TransactionDate.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>@Localizer[item.Category.CategoryName]</td>
                                <td class="text-danger fw-bold">-@item.Amount.ToString("N0")</td>
                                <td>@item.Description</td>
                                <td>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.TransactionId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('@confirmDelete');">
                                            @Localizer["Delete"]
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
