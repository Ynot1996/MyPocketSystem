@model IEnumerable<MyPocket.Core.Models.Transaction>
@{
    var categoryError = ViewData.ModelState["CategoryId"]?.Errors.FirstOrDefault()?.ErrorMessage;
    var categories = ViewBag.Categories as IEnumerable<SelectListItem>;
}
<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="card-title mb-3 fw-bold text-primary">@Localizer["AddTransaction"]</h5>
        <form asp-action="Create" method="post" autocomplete="off">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-3">
                <label for="CategoryId" class="form-label">@Localizer["Category"] <span class="text-danger">*</span></label>
                <select name="CategoryId" id="CategoryId" class="form-select" required>
                    <option value="">-- @Localizer["SelectCategory"] --</option>
                    @if (categories != null && categories.Any())
                    {
                        foreach (var categoryGroup in categories.Where(c => c.Group != null).GroupBy(c => c.Group.Name))
                        {
                            <optgroup label="@Localizer[categoryGroup.Key]">
                                @foreach (var category in categoryGroup)
                                {
                                    <option value="@category.Value">@Localizer[category.Text]</option>
                                }
                            </optgroup>
                        }
                        // Fall through any categories that were not assigned to a group.
                        var noGroupCategories = categories.Where(c => c.Group == null);
                        foreach (var category in noGroupCategories)
                        {
                            <option value="@category.Value">@Localizer[category.Text]</option>
                        }
                    }
                    else
                    {
                        <option value="">@Localizer["NoCategoriesFound"]</option>
                    }
                </select>
                @if (!string.IsNullOrEmpty(categoryError))
                {
                    <span class="text-danger small">@categoryError</span>
                }
            </div>
            <div class="mb-3">
                <label for="Amount" class="form-label">@Localizer["Amount"] <span class="text-danger">*</span></label>
                <input type="number" name="Amount" class="form-control" step="0.01" min="0" required />
            </div>
            <div class="mb-3">
                <label for="TransactionDate" class="form-label">@Localizer["TransactionDate"] <span class="text-danger">*</span></label>
                <input type="datetime-local" name="TransactionDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
            </div>
            <div class="mb-3">
                <label for="Description" class="form-label">@Localizer["Description"]</label>
                <textarea name="Description" class="form-control" rows="2" maxlength="100"></textarea>
            </div>
            <button type="submit" class="btn btn-primary w-100">@Localizer["Add"]</button>
        </form>
    </div>
</div>
