@model MyPocket.Shared.ViewModels.Budgets.BudgetViewModel
@{
    ViewData["Title"] = Localizer["BudgetDetails"];
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}
<h2>@Localizer["BudgetDetails"]</h2>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Category"]</dt>
    <dd class="col-sm-9">@Localizer[Model.CategoryName]</dd>
    <dt class="col-sm-3">@Localizer["BudgetAmount"]</dt>
    <dd class="col-sm-9">@Model.Amount.ToString("N0")</dd>
    <dt class="col-sm-3">@Localizer["Spent"]</dt>
    <dd class="col-sm-9">@Model.Spent.ToString("N0")</dd>
    <dt class="col-sm-3">@Localizer["Remaining"]</dt>
    <dd class="col-sm-9">@Model.Remaining.ToString("N0")</dd>
    <dt class="col-sm-3">@Localizer["Year"]</dt>
    <dd class="col-sm-9">@Model.BudgetYear</dd>
    <dt class="col-sm-3">@Localizer["Month"]</dt>
    <dd class="col-sm-9">@Model.BudgetMonth</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.BudgetId" class="btn btn-primary">@Localizer["Edit"]</a>
<a asp-action="Delete" asp-route-id="@Model.BudgetId" class="btn btn-danger">@Localizer["Delete"]</a>
<a asp-action="Index" class="btn btn-secondary">@Localizer["BackToList"]</a>
