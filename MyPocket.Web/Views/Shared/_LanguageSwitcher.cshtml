@using System.Globalization
@{
    var currentCulture = CultureInfo.CurrentUICulture.Name;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var target = currentCulture == "zh-TW" ? "en-US" : "zh-TW";
    var label = currentCulture == "zh-TW" ? "EN" : "中";
    var title = currentCulture == "zh-TW" ? "Switch to English" : "切換為中文";
}
<form method="post" asp-area="" asp-controller="Language" asp-action="Set" class="d-inline">
    @Html.AntiForgeryToken()
    <input type="hidden" name="culture" value="@target" />
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <button type="submit" class="btn btn-sm btn-outline-secondary" title="@title">@label</button>
</form>
